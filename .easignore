# EAS uses .easignore instead of .gitignore when present, so this mirrors
# .gitignore and additionally excludes the local root native projects so EAS
# does a clean managed (CNG) prebuild — matching how production builds are made.
# (The leading slash anchors to root, so modules/drawing-canvas/ios is kept.)

# Native projects — force a managed prebuild on EAS
/ios
/android

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Firebase admin SDK private keys — NEVER commit
*firebase-adminsdk*.json
*service-account*.json
